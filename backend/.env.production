# SignConnect Backend - Production Environment Variables
# Copy this file and fill in your production values

# Server Configuration
PORT=5001
NODE_ENV=production

# Database (PostgreSQL for Production)
DATABASE_URL=postgresql://username:password@host:5432/signconnect?schema=public

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_at_least_32_characters_long
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Error Tracking (Optional but Recommended)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# OpenAI (Optional - for enhanced NLP features)
OPENAI_API_KEY=your_openai_api_key_if_needed

# Logging
LOG_LEVEL=info
